<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- SDL/Skia backend of the Platform Abstraction Layer. Implements the
         engine's IGameWindow + IRenderer. The engine itself depends on neither
         SDL nor Skia; only this assembly does. -->
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>AsteroidsEngine.Platform.Sdl</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../AsteroidsEngine.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Silk.NET.SDL" Version="2.21.0" />
    <PackageReference Include="SkiaSharp" Version="2.88.7" />
  </ItemGroup>

</Project>
